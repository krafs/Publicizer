{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "Krafs.Publicizer",
      "include-component-in-tag": false,
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        "src/Publicizer/Publicizer.csproj"
      ]
    }
  },
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Fixes & Improvements" },
    { "type": "perf", "section": "Fixes & Improvements" },
    { "type": "deps", "section": "Dependencies" },
    { "type": "build", "section": "Build & CI", "hidden": true },
    { "type": "ci", "section": "Build & CI", "hidden": true },
    { "type": "docs", "section": "Documentation", "hidden": true },
    { "type": "refactor", "section": "Other", "hidden": true },
    { "type": "test", "section": "Other", "hidden": true },
    { "type": "chore", "section": "Other", "hidden": true }
  ]
}
